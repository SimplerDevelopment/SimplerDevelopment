#!/usr/bin/env bash
# Fast pre-commit checks for simplerdevelopment2026 (staged files only).
# Heavy gates (tsc, tests) run at pre-push, not here. One-off bypass: git commit --no-verify
set -uo pipefail
PROJ="simplerdevelopment2026"
ROOT="$(git rev-parse --show-toplevel)"

staged="$(git diff --cached --name-only --diff-filter=ACMR | grep "^$PROJ/" || true)"
[ -z "$staged" ] && exit 0

cd "$ROOT/$PROJ"
rel="$(echo "$staged" | sed "s#^$PROJ/##")"
ts_files="$(echo "$rel" | grep -E '\.(ts|tsx)$' || true)"

fail=0
if [ -n "$ts_files" ]; then
  echo "pre-commit: eslint (staged)…"
  # Fail on errors only (warnings are the existing backlog); this stops NEW
  # errors landing in files you touch without forcing a repo-wide cleanup first.
  echo "$ts_files" | xargs bunx eslint || fail=1
fi
echo "pre-commit: file-size budget…"
bun scripts/check-file-budget.ts || fail=1
echo "pre-commit: doc drift…"
bun scripts/check-doc-drift.ts || fail=1

if [ "$fail" -ne 0 ]; then
  echo "pre-commit failed. Fix the above, or bypass once with: git commit --no-verify"
  exit 1
fi
exit 0

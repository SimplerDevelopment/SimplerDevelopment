#!/usr/bin/env bash
# Local-CI gate for simplerdevelopment2026.
# This repo holds several projects, so the hook only runs when the push actually
# touches simplerdevelopment2026/. One-off bypass: git push --no-verify
set -uo pipefail
PROJ="simplerdevelopment2026"
ROOT="$(git rev-parse --show-toplevel)"
ZERO="0000000000000000000000000000000000000000"

touches=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
  [ -z "${local_sha:-}" ] && continue
  [ "$local_sha" = "$ZERO" ] && continue   # branch deletion
  if [ "$remote_sha" = "$ZERO" ]; then
    changed="$(git show --name-only --format= "$local_sha" 2>/dev/null)"   # new branch/ref
  else
    changed="$(git diff --name-only "$remote_sha..$local_sha" 2>/dev/null)"
  fi
  echo "$changed" | grep -q "^$PROJ/" && touches=1
done

if [ "$touches" = 0 ]; then
  echo "pre-push: no $PROJ/ changes — skipping its local CI."
  exit 0
fi

echo "pre-push: running $PROJ local CI…"
cd "$ROOT/$PROJ" && exec scripts/ci-local.sh

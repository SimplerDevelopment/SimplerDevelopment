# SD Chat Mobile — environment

# Backend base URL. Defaults to https://staging.simplerdevelopment.com.
# Override locally (e.g. http://localhost:3000) by copying this file to .env.local.
EXPO_PUBLIC_API_URL=https://staging.simplerdevelopment.com

# AI streaming endpoint, used by Phase 2 D / Phase 3.
EXPO_PUBLIC_AI_STREAM_PATH=/api/ai/stream

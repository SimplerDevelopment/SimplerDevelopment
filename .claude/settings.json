{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Project-scoped settings for simplerdevelopment2026. Merges with user-global settings (~/.claude/settings.json) — both fire. See CLAUDE.md for context.",
  "permissions": {
    "allow": [
      "Bash(bun:*)",
      "Bash(bun run:*)",
      "Bash(bun test:*)",
      "Bash(bun add:*)",
      "Bash(bun remove:*)",
      "Bash(bun install)",
      "Bash(scripts/test.sh:*)",
      "Bash(npx tsc:*)",
      "Bash(tsc:*)",
      "Bash(drizzle-kit:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh api:*)"
    ],
    "deny": [
      "Edit(bun.lock)",
      "Write(bun.lock)",
      "Edit(drizzle/**)",
      "Write(drizzle/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-bash.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/fallow-gate.sh",
            "timeout": 180
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-config-writes.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/touched-marker.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-qa-gate.sh",
            "timeout": 300
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/cost-log.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}

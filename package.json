{
  "name": "simplerdevelopment2026",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/realtime-server",
    "packages/sdk",
    "workers/email-inbound"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:all": "turbo run build",
    "start": "next start",
    "lint": "eslint",
    "lint:all": "turbo run lint",
    "typecheck": "node --max-old-space-size=6144 node_modules/.bin/tsc --noEmit",
    "typecheck:all": "turbo run typecheck",
    "typecheck:fast": "bunx @typescript/native-preview --noEmit",
    "test": "scripts/test.sh --layer=unit --no-coverage",
    "test:unit": "scripts/test.sh --layer=unit --no-coverage",
    "test:integration": "scripts/test.sh --layer=integration --no-coverage",
    "test:integration:local": "./scripts/start-local-db.sh && DATABASE_URL='postgresql://'$USER'@localhost:5432/simplerdev_test' DATABASE_URL_TEST='postgresql://'$USER'@localhost:5432/simplerdev_test' scripts/test.sh --layer=integration --no-coverage",
    "test:e2e": "scripts/test.sh --layer=e2e --no-coverage",
    "test:all": "scripts/test.sh",
    "test:coverage": "scripts/test.sh",
    "test:coverage:prod": "scripts/test.sh --mode=prod",
    "test:critical": "scripts/test.sh --layer=e2e --tag=@critical --no-coverage",
    "test:e2e:local": "./scripts/prepare-e2e-local.sh && DATABASE_URL='postgresql://'$USER'@localhost:5432/simplerdev_test' scripts/test.sh --layer=e2e --no-coverage",
    "test:critical:local": "./scripts/prepare-e2e-local.sh && DATABASE_URL='postgresql://'$USER'@localhost:5432/simplerdev_test' scripts/test.sh --layer=e2e --tag=@critical --no-coverage",
    "test:tenancy": "scripts/test.sh --layer=integration --tag=tenancy --no-coverage",
    "smoke:skills": "bun scripts/smoke-sd-skills.ts run",
    "smoke:skills:seed-key": "bun scripts/smoke-sd-skills.ts seed-key",
    "smoke:skills:cleanup": "bun scripts/smoke-sd-skills.ts cleanup",
    "skills:bundle": "bun scripts/build-client-skills-bundle.ts",
    "build:installer:mac": "bash scripts/installers/build-mac-pkg.sh",
    "build:installer:windows": "bash scripts/installers/build-windows-msi.sh",
    "test:ui": "vitest --ui",
    "test:e2e:ui": "playwright test --ui",
    "test:vitest": "vitest",
    "db:verify-target": "tsx scripts/verify-db-target.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npm run db:verify-target && drizzle-kit migrate",
    "db:push": "npm run db:verify-target && drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed-admin.ts",
    "db:seed:dev": "tsx scripts/seed-dev.ts",
    "db:seed:admin-e2e": "tsx scripts/seed-admin-e2e.ts",
    "db:seed:brain-taxonomy": "tsx scripts/brain/seed-taxonomy-topics.ts",
    "backfill:brain-taxonomy:preview": "tsx scripts/brain/backfill-taxonomy.ts --mode=preview",
    "backfill:brain-taxonomy:apply": "tsx scripts/brain/backfill-taxonomy.ts --mode=apply",
    "eval:brain": "bun run lib/ai/brain-tools/eval/runner.ts",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/extension/node_modules
/extension/dist
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# Sentry
.sentryclirc
.env.sentry-build-plugin

# typescript
*.tsbuildinfo
next-env.d.ts

# screenshots / QA artifacts
*.jpeg
*.jpg
*.png
!public/**/*.png
!public/**/*.jpg
!public/**/*.jpeg
/qa-screenshots/

# playwright HTML report (run artifact, not source)
/playwright-report/

# claude code local state
/.claude/scheduled_tasks.lock
/.claude/.runtime/

# DB backup dumps (large, sensitive)
/.migration-backup/
/.backups/

# one-off debug scripts and editor snapshots
_tmp-*
**/_tmp-*
editor-snapshot.md
audit-verify-*

# Probe / compare / inspect debug artifacts (per CLAUDE.md)
scripts/_*
public/_cmp*
public/_cmp/
.planning/postcaptain-replication/_probe-*.mjs
.planning/postcaptain-replication/probe-*.mjs
backups/

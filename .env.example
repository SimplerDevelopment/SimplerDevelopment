# ── Plugin registry ────────────────────────────────────────────
# 32-byte base64 key used to AES-GCM-encrypt the secretEncrypted column
# of registered_app_signing_keys. Without this, plugin JWT verification
# falls back to a fixed dev key with a console.warn — UNSAFE FOR PROD.
# Generate: openssl rand -base64 32
PORTAL_KMS_KEY=

# Optional: bypass entitlement checks for local dev (1 = bypass).
PLUGINS_ENTITLEMENT_BYPASS=

# Optional: bypass Origin header check on plugin callbacks (1 = bypass).
PLUGINS_CALLBACK_ORIGIN_BYPASS=

# Anthropic API key used by the postcaptain-tools research/draft runners.
# Required if any active plugin job uses kind=research-brief or draft-blog-post.
ANTHROPIC_API_KEY=

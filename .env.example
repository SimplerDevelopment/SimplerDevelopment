# SimplerDevelopment — environment template.
# Copy to .env.local and fill in. Only the "Core" block is needed to boot;
# the rest enable individual integrations and can stay blank in local dev.
# Never commit your real .env.local — it is gitignored.

# ── Core (required to run) ─────────────────────────────────────
# Postgres connection string. The schema needs the pgvector extension:
#   CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL=postgresql://user:password@localhost:5432/simplerdev

# NextAuth (v5) session secret. Generate: openssl rand -base64 32
# AUTH_SECRET is the v5 name; NEXTAUTH_SECRET is read as a fallback.
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# SELF-HOSTERS: pin the session cookie to your apex domain so sign-in works and
# sessions are shared across subdomains, e.g. `.example.com`. Leave blank for
# localhost / single-host deploys (cookie stays host-only). Must start with a dot
# to cover subdomains.
AUTH_COOKIE_DOMAIN=

# Shared secret that protects cron endpoints (/api/cron/*). Generate: openssl rand -hex 32
CRON_SECRET=

# ── Rate limiting (Upstash Redis) ──────────────────────────────
# Shared store that makes the auth rate limiter (lib/security/rate-limit.ts)
# global across Vercel serverless instances. WITHOUT these, the limiter falls
# back to a per-instance in-memory window (fine for local dev, weak in prod).
# Create a free Redis DB at console.upstash.com -> copy the REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Plugin registry / signing ──────────────────────────────────
# 32-byte base64 key used to AES-GCM-encrypt the secretEncrypted column of
# registered_app_signing_keys. Without it, plugin JWT verification falls back
# to a fixed dev key with a console.warn — UNSAFE FOR PROD. Generate: openssl rand -base64 32
PORTAL_KMS_KEY=
# Per-tenant Google Workspace credential encryption key (if using Workspace).
WORKSPACE_TENANT_SECRETS_KEY=
# AES-256-GCM key for encrypting stored integration API keys (BYOK). Required —
# the integrations API-keys route returns 500 without it. Must be 64 hex chars
# (32 bytes). Generate: openssl rand -hex 32
ENCRYPTION_KEY=
# Optional local-dev bypasses (1 = bypass).
PLUGINS_ENTITLEMENT_BYPASS=
PLUGINS_CALLBACK_ORIGIN_BYPASS=

# ── AI ─────────────────────────────────────────────────────────
# Platform-level Anthropic key (also the BYOK fallback). Required for AI features
# and for plugin jobs of kind=research-brief / draft-blog-post.
ANTHROPIC_API_KEY=
# OpenAI key — used for Company Brain embeddings (text-embedding-3-small).
OPENAI_API_KEY=

# ── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Shared secret for inbound-email webhook verification.
INBOUND_EMAIL_SECRET=

# ── Billing (Stripe) ───────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ECOMMERCE_WEBHOOK_SECRET=
STRIPE_BOOKING_WEBHOOK_SECRET=

# ── File storage (S3-compatible) ───────────────────────────────
S3_ENDPOINT=
S3_REGION=
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
MAX_FILE_SIZE=
ALLOWED_FILE_TYPES=

# ── OAuth / third-party integrations (all optional) ────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
MICROSOFT_TEAMS_CLIENT_ID=
MICROSOFT_TEAMS_CLIENT_SECRET=
# LinkedIn (personal-profile posting). App at developer.linkedin.com with the
# "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn" products.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Optional: LinkedIn REST API version (YYYYMM). Defaults to 202606.
LINKEDIN_API_VERSION=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# E-signature (Dropbox Sign).
DROPBOX_SIGN_API_KEY=
# OAuth CSRF state-nonce secret. Generate: openssl rand -hex 32
OAUTH_STATE_SECRET=
# Google Fonts API key for the visual-editor font picker (/api/google-fonts).
# Without it the font-picker endpoint returns 503. Create one in Google Cloud
# Console -> APIs & Services -> Credentials, enable "Web Fonts Developer API",
# and restrict it by HTTP referrer / API.
GOOGLE_FONTS_API_KEY=

# ── Contact / email overrides ───────────────────────────────────
# Override platform contact addresses without changing source code.
CONTACT_INBOX=info@simplerdevelopment.com
BILLING_EMAIL=billing@simplerdevelopment.com
SUPPORT_EMAIL=support@simplerdevelopment.com
NEXT_PUBLIC_CONTACT_EMAIL=info@simplerdevelopment.com

{
  "name": "@simplerdevelopment/realtime-server",
  "version": "0.1.0",
  "private": true,
  "description": "Yjs WebSocket server with debounced Postgres snapshot persistence and an internal HTTP write channel for MCP fan-out.",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2",
    "lib0": "^0.2.99",
    "postgres": "^3.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "ws": "^8.18.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.20"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1"
  },
  "engines": {
    "node": ">=20"
  }
}

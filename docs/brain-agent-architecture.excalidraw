    {"type":"text","id":"tools_text","x":1296,"y":252,"width":698,"height":912,"text":"brain_search\nhybrid full-text + semantic, multi-type\n\nbrain_dashboard_summary\ncounts · open tasks · at-risk goals\n\nbrain_get_note\nread note by ID (full markdown body)\n\nbrain_create_note\ncreate with title, body, tags, pinned\n\nbrain_list_decisions\nfilter by status: proposed/accepted/rejected\n\nbrain_get_decision\nread single decision + supersede chain\n\nbrain_list_people\ndirectory: name, title, org unit\n\nbrain_lookup_glossary\nexact + prefix + substring match\n\nbrain_list_glossary\nbrowse all active terms by category\n\nbrain_list_initiatives\nstrategic multi-quarter efforts\n\nbrain_list_tasks\nopen tasks, filter by status\n\nbrain_create_task\ncreate with title, priority, due date","originalText":"brain_search\nhybrid full-text + semantic, multi-type\n\nbrain_dashboard_summary\ncounts · open tasks · at-risk goals\n\nbrain_get_note\nread note by ID (full markdown body)\n\nbrain_create_note\ncreate with title, body, tags, pinned\n\nbrain_list_decisions\nfilter by status: proposed/accepted/rejected\n\nbrain_get_decision\nread single decision + supersede chain\n\nbrain_list_people\ndirectory: name, title, org unit\n\nbrain_lookup_glossary\nexact + prefix + substring match\n\nbrain_list_glossary\nbrowse all active terms by category\n\nbrain_list_initiatives\nstrategic multi-quarter efforts\n\nbrain_list_tasks\nopen tasks, filter by status\n\nbrain_create_task\ncreate with title, priority, due date","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e3a5f","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":50005,"version":1,"versionNonce":50006,"isDeleted":false,"groupIds":[],"link":null,"locked":false,"containerId":"tools_rect","lineHeight":1.5},

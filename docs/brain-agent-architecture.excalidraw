    {"type":"text","id":"hooks_text","x":1296,"y":1240,"width":698,"height":486,"text":"sanitizeToolResult()  — deterministic, always runs\n\nsk-...              → [REDACTED_API_KEY]\nBearer ...          → [REDACTED_TOKEN]\nghp_...             → [REDACTED_GH_TOKEN]\nxoxb-...            → [REDACTED_SLACK_TOKEN]\n\"password\": \"...\"   → [REDACTED]\n123-45-6789         → [REDACTED_SSN]\n4111111111111111    → [REDACTED_CC]\n\n──────────────────────────────────────────\n\nwithSpan(name, attrs, fn)  — always wraps\n\n{ span: \"brain_tool.brain_search\",\n  duration_ms: 142,\n  ok: true,\n  clientId: 7,\n  convId: 381 }","originalText":"sanitizeToolResult()  — deterministic, always runs\n\nsk-...              → [REDACTED_API_KEY]\nBearer ...          → [REDACTED_TOKEN]\nghp_...             → [REDACTED_GH_TOKEN]\nxoxb-...            → [REDACTED_SLACK_TOKEN]\n\"password\": \"...\"   → [REDACTED]\n123-45-6789         → [REDACTED_SSN]\n4111111111111111    → [REDACTED_CC]\n\n──────────────────────────────────────────\n\nwithSpan(name, attrs, fn)  — always wraps\n\n{ span: \"brain_tool.brain_search\",\n  duration_ms: 142,\n  ok: true,\n  clientId: 7,\n  convId: 381 }","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#22c55e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":60005,"version":1,"versionNonce":60006,"isDeleted":false,"groupIds":[],"link":null,"locked":false,"containerId":"hooks_rect","lineHeight":1.5},

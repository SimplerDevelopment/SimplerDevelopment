{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "next": {
    "entry": [
      "next.config.{js,ts,mjs}",
      "middleware.ts",
      "instrumentation.ts",
      "app/**/{page,layout,route,loading,error,not-found,template,default,sitemap,robots,opengraph-image,icon}.{ts,tsx}"
    ]
  },
  "entry": [
    "scripts/**/*.ts",
    "workers/**/*.{ts,tsx}",
    "drizzle.config.ts",
    "playwright.config.ts",
    "vitest.config.{ts,mts}",
    "tests/**/*.{test,spec}.{ts,tsx}"
  ],
  "project": ["app/**/*.{ts,tsx}", "lib/**/*.{ts,tsx}", "components/**/*.{ts,tsx}"],
  "ignore": ["**/node_modules/**", ".next/**", "packages/sdk/**", "extension/**", "drizzle/**"],
  "ignoreBinaries": ["bun", "tsc", "depcruise"],
  "ignoreDependencies": []
}

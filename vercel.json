{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/expire-mcp-pendings",
      "schedule": "17 3 * * *"
    },
    {
      "path": "/api/cron/renew-gmail-watches",
      "schedule": "47 3 * * *"
    },
    {
      "path": "/api/cron/renew-drive-watches",
      "schedule": "13 4 * * *"
    },
    {
      "path": "/api/cron/drive-sync",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/process-embeddings",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/brain-daily-notes",
      "schedule": "5 6 * * *"
    },
    {
      "path": "/api/cron/brain-empty-old-trash",
      "schedule": "15 7 * * *"
    },
    {
      "path": "/api/cron/failing-automations-notify",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/surveys-zero-responses",
      "schedule": "30 10 * * 1"
    },
    {
      "path": "/api/cron/stale-crm-deals",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/cron/stuck-booking-holds",
      "schedule": "*/30 * * * *"
    }
  ]
}
